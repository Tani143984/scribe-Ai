# =============================================
# COPY THIS FILE TO .env.local
# Never commit .env.local to git!
# =============================================

# --- DATABASE ---
# Get this from Railway (free) or run locally with Docker
DATABASE_URL="postgresql://postgres:password@localhost:5432/scribeai"

# --- NEXTAUTH ---
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# --- GOOGLE OAUTH (optional but recommended) ---
# Create at: https://console.cloud.google.com
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# --- AI API ---
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# OR use OpenAI:
# OPENAI_API_KEY="sk-..."

# --- STRIPE ---
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook secret — get after running: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs — create these in Stripe dashboard
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_TEAM_PRICE_ID="price_..."
